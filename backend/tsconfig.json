{
    "compilerOptions": {
        "outDir": "./dist",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "lib": ["ES2022"],
        "skipLibCheck": true,
        "isolatedModules": true,
        "allowJs": true,
        "esModuleInterop": true,
        "strict": false,
        "noUncheckedIndexedAccess": true,
        "verbatimModuleSyntax": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": ["server.ts", "app.ts", "src/**/*.ts"],
    "exclude": ["node_modules"]
}
